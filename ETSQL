
CREATE Database ExpenseTracker


CREATE TABLE skey_user(
id_user INT IDENTITY (1,1) PRIMARY KEY,
loginname VARCHAR(300),
fullname VARCHAR(300),
password VARBINARY(32)
is_active INT,
uuqid UNIQUEIDENTIFIER,
regid VARCHAR(500),
os VARCHAR(100), 
createdby INT,
createddt DATETIME
)

CREATE TABLE ekey_expense(
id_expense INT IDENTITY (1,1) PRIMARY KEY,
title VARCHAR(300),
expense INT,
category VARCHAR(300),
message VARCHAR(500),
createdby INT,
createddt DATETIME,
modifiedby INT,
modifieddt DATETIME
)

CREATE TABLE  ekey_budget(
id_budget INT IDENTITY(1,1) PRIMARY KEY,
title VARCHAR(300),
expense INT,
category VARCHAR(300),
message VARCHAR(500),
createdby INT,
createddt DATETIME,
modifiedby INT,
modifieddt DATETIME 

)

