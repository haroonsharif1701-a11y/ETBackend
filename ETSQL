CREATE PROCEDURE loginverify
(
    @loginname VARCHAR(300),
    @password VARBINARY(500)  -- hashed password
)
AS
BEGIN
    SET NOCOUNT ON;

    -- Basic validation
    IF (@loginname IS NULL OR @password IS NULL)
    BEGIN
        SELECT 
            0 AS status,
            'Invalid input' AS message;
        RETURN;
    END

    -- Authenticate user
    SELECT 
        id_user,
        loginname,
        fullname,
        is_active
    FROM skey_user
    WHERE 
        loginname = @loginname
        AND password = @password
        AND is_active = 1;

    -- If no rows → invalid login
    IF @@ROWCOUNT = 0
    BEGIN
        SELECT 
            0 AS status,
            'Invalid credentials or inactive user' AS message;
    END
    ELSE
    BEGIN
        SELECT 
            1 AS status,
            'Login successful' AS message;
    END
END


