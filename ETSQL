CREATE PROCEDURE user_delete
(
    @id_user INT
)
AS
BEGIN
    SET NOCOUNT ON;

    -- Soft delete (deactivate)
    UPDATE skey_user
    SET is_active = 0
    WHERE id_user = @id_user;

    IF (@@ROWCOUNT = 0)
    BEGIN
        SELECT 0 AS status, 'User not found' AS message;
    END
    ELSE
    BEGIN
        SELECT 1 AS status, 'User deactivated successfully' AS message;
    END
END
