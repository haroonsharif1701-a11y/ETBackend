CREATE PROCEDURE user_addupd
(
    @id_user INT = 0 OUTPUT,
    @loginname VARCHAR(300),
    @fullname VARCHAR(300),
    @password VARCHAR(300) = NULL, -- plain input, will hash
    @is_active INT = 1,
    @regid VARCHAR(500) = NULL,
    @os VARCHAR(100) = NULL,
    @createdby INT = NULL
)
AS
BEGIN
    SET NOCOUNT ON;

    -- Validate loginname
    IF (@loginname IS NULL OR LTRIM(RTRIM(@loginname)) = '')
    BEGIN
        SELECT 0 AS status, 'Login name required' AS message;
        RETURN;
    END

    -- Check duplicate loginname (excluding current user)
    IF EXISTS (
        SELECT 1 FROM skey_user 
        WHERE loginname = @loginname 
        AND id_user <> ISNULL(@id_user, 0)
    )
    BEGIN
        SELECT 0 AS status, 'Login already exists' AS message;
        RETURN;
    END

    -- INSERT
    IF (@id_user IS NULL OR @id_user = 0)
    BEGIN
        INSERT INTO skey_user
        (
            loginname,
            fullname,
            password,
            is_active,
            uuqid,
            regid,
            os,
            createdby,
            createddt
        )
        VALUES
        (
            @loginname,
            @fullname,
            HASHBYTES('SHA2_256', ISNULL(@password,'')),
            @is_active,
            NEWID(),
            @regid,
            @os,
            @createdby,
            GETDATE()
        );

        SET @id_user = SCOPE_IDENTITY();

        SELECT 1 AS status, 'User created successfully' AS message, @id_user AS id_user;
    END
    ELSE
    BEGIN
        -- UPDATE
        UPDATE skey_user
        SET
            loginname = @loginname,
            fullname = @fullname,
            is_active = @is_active,
            regid = @regid,
            os = @os,
            password = CASE 
                        WHEN @password IS NOT NULL 
                        THEN HASHBYTES('SHA2_256', @password)
                        ELSE password
                       END
        WHERE id_user = @id_user;

        IF (@@ROWCOUNT = 0)
        BEGIN
            SELECT 0 AS status, 'User not found' AS message;
        END
        ELSE
        BEGIN
            SELECT 1 AS status, 'User updated successfully' AS message, @id_user AS id_user;
        END
    END
END
