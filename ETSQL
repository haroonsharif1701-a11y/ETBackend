CREATE PROCEDURE expense_addupd
(
    @id_expense INT = 0 OUTPUT,
    @title VARCHAR(300),
    @expense INT,
    @category VARCHAR(300),
    @message VARCHAR(500),
    @uuqid UNIQUEIDENTIFIER
)
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @id_user INT;

    -- Get user
    SELECT @id_user = id_user
    FROM skey_user
    WHERE uuqid = @uuqid;

    -- Validation
    IF (@id_user IS NULL)
    BEGIN
        SELECT 0 AS status, 'Invalid user' AS message;
        RETURN;
    END

    -- INSERT
    IF (@id_expense IS NULL OR @id_expense = 0)
    BEGIN
        INSERT INTO ekey_expense
        (
            title,
            expense,
            category,
            message,
            createdby,
            createddt
        )
        VALUES
        (
            @title,
            @expense,
            @category,
            @message,
            @id_user,
            GETDATE()
        );

        SET @id_expense = SCOPE_IDENTITY();

        SELECT 1 AS status, 'Inserted successfully' AS message, @id_expense AS id_expense;
    END
    ELSE
    BEGIN
        -- UPDATE
        UPDATE ekey_expense
        SET
            title = @title,
            expense = @expense,
            category = @category,
            message = @message,
            modifiedby = @id_user,
            modifieddt = GETDATE()
        WHERE id_expense = @id_expense;

        IF (@@ROWCOUNT = 0)
        BEGIN
            SELECT 0 AS status, 'Expense not found' AS message;
        END
        ELSE
        BEGIN
            SELECT 1 AS status, 'Updated successfully' AS message, @id_expense AS id_expense;
        END
    END
END
