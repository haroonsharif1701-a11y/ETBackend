CREATE PROCEDURE expense_del
(
    @id_expense INT,
    @uuqid UNIQUEIDENTIFIER
)
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @id_user INT;

    -- Resolve user
    SELECT @id_user = id_user
    FROM skey_user
    WHERE uuqid = @uuqid;

    -- Validate user
    IF (@id_user IS NULL)
    BEGIN
        SELECT 0 AS status, 'Invalid user' AS message;
        RETURN;
    END

    -- Delete (restrict to user's own data)
    DELETE FROM ekey_expense
    WHERE id_expense = @id_expense
      AND createdby = @id_user;

    IF (@@ROWCOUNT = 0)
    BEGIN
        SELECT 0 AS status, 'Expense not found or unauthorized' AS message;
    END
    ELSE
    BEGIN
        SELECT 1 AS status, 'Deleted successfully' AS message;
    END
END
